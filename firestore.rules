rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        (request.auth.token.email == 'biolucas@gmail.com' && request.auth.token.email_verified == true)
      );
    }
    
    function isGestorVendas() {
      return isAuthenticated() && getUserData().role == 'gestor_vendas';
    }
    
    function isGestorTrafego() {
      return isAuthenticated() && getUserData().role == 'gestor_trafego';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    // Leads collection
    match /leads/{leadId} {
      allow read: if isAdmin() || isGestorVendas() || isGestorTrafego();
      allow create: if isAdmin() || isGestorVendas() || isGestorTrafego();
      allow update: if isAdmin() || isGestorVendas() || isGestorTrafego();
      allow delete: if isAdmin();
    }
    
    match /leads_dev/{leadId} {
      allow read, write: if isAuthenticated();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isGestorVendas();
    }
    
    match /orders_dev/{orderId} {
      allow read, write: if isAuthenticated();
    }

    // Authorized Emails
    match /authorized_emails/{emailId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
