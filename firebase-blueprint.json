{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." }
      },
      "required": ["uid", "email", "role"]
    },
    "ProductMapping": {
      "title": "ProductMapping",
      "description": "Maps an App product (name, weight, grind) to a Bling SKU.",
      "type": "object",
      "properties": {
        "appName": { "type": "string", "description": "The name of the product in the App." },
        "appWeight": { "type": "string", "description": "The weight of the product in the App." },
        "appGrind": { "type": "string", "description": "The grind type of the product in the App." },
        "blingId": { "type": "string", "description": "The ID of the product in Bling." },
        "blingSku": { "type": "string", "description": "The SKU of the product in Bling." },
        "blingName": { "type": "string", "description": "The name of the product in Bling." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appName", "appWeight", "appGrind", "blingSku"]
    },
    "BlingConfig": {
      "title": "BlingConfig",
      "description": "Stores Bling API tokens.",
      "type": "object",
      "properties": {
        "access_token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "expires_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["access_token", "refresh_token", "expires_at"]
    },
    "BlingCustomer": {
      "title": "BlingCustomer",
      "description": "Cached customer data from Bling for deep searching.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "nome": { "type": "string" },
        "fantasia": { "type": "string" },
        "numeroDocumento": { "type": "string" },
        "tipo": { "type": "string" },
        "searchTerms": { "type": "array", "items": { "type": "string" } },
        "dadosCompletos": { "type": "object", "description": "The full raw customer data from Bling API" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "nome"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a production order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "tradeName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "statusHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "archived": { "type": "boolean" },
        "archivedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles."
    },
    "/product_mapping/{mappingId}": {
      "schema": { "$ref": "ProductMapping" },
      "description": "Product mappings."
    },
    "/bling_config/tokens": {
      "schema": { "$ref": "BlingConfig" },
      "description": "Bling API tokens."
    },
    "/bling_customers/{customerId}": {
      "schema": { "$ref": "BlingCustomer" },
      "description": "Cached Bling customers."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Production orders."
    },
    "/orders_dev/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Development/test orders."
    }
  }
}
